PORT=3000
# Local: mongodb://127.0.0.1:27017/crowdconnect
# Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/crowdconnect?retryWrites=true&w=majority
# If the password has @ # etc., URL-encode it (e.g. @ → %40)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/crowdconnect?retryWrites=true&w=majority
# If you see querySrv ECONNREFUSED on Windows, set to 1 (uses Google DNS for SRV only in this app)
MONGODB_ATLAS_PUBLIC_DNS=1
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Payment gateways (optional — mock mode when unset)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PLATFORM_FEE_PERCENT=2
